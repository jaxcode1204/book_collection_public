<h1>Books</h1>

<p><%= link_to "Add a Book", home_add_path %></p>

<table>
  <thead>
    <tr>
      <th>Title</th>
      <th colspan="3"></th>
    </tr>
  </thead>
  <tbody>
    <% @books.each do |book| %>
      <tr>
        <td><%= book.title %></td>
        <td><%= link_to "Details", home_details_path(id: book.id) %></td>
        <td><%= link_to "Update",  home_update_path(id: book.id)  %></td>
        <td><%= link_to "Delete",  home_delete_path(id: book.id)  %></td>
      </tr>
    <% end %>
  </tbody>
</table>